{
   "action": {
      "default_icon": {
         "128": "icons/128.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content-script.js" ],
      "matches": [ "https://web.telegram.org/*" ],
      "run_at": "document_end"
   } ],
   "default_locale": "en",
   "description": "__MSG_desc__",
   "host_permissions": [ "https://web.telegram.org/*" ],
   "icons": {
      "128": "icons/128.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_name__",
   "permissions": [ "storage", "activeTab", "identity" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.4.1",
   "web_accessible_resources": [ {
      "matches": [ "*://*/*" ],
      "resources": [ "popup.html", "fonts/*", "icons/*", "content-script-inject.js", "content-scripting-a.js", "content-scripting-k.js" ]
   }, {
      "matches": [ "https://*.igtools.ai/*", "https://*.vidsaver.io/*" ],
      "resources": [ "price.html" ]
   } ]
}
